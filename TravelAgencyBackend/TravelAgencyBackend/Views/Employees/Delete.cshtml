@model TravelAgencyBackend.ViewModels.EmployeeDeleteViewModel

@{
    ViewData["Title"] = "Delete";
}

<h1 class="text-danger">刪除員工資料</h1>

<div class="alert alert-warning">
    <strong>注意：</strong> 這項操作將永久刪除員工資料，無法復原。
</div>

<table class="table table-bordered">
    <tr>
        <th>姓名</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>職稱</th>
        <td>@Model.RoleName</td>
    </tr>
</table>

<form asp-action="Delete">
    <input type="hidden" asp-for="EmployeeId" />
    <button type="submit" class="btn btn-danger">確認刪除</button>
    <a asp-action="List" class="btn btn-secondary">返回員工列表</a>
</form>
